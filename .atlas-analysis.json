  "keyFeatures": [
    "Headless agent registration in <500ms",
    "Ed25519 challenge-response authentication",
    "x402 payment protocol integration",
    "Multi-framework support (Express, Next.js, Hono, Fastify, FastAPI)",
    "Agent traffic detection",
    "Pluggable storage (Memory, SQLite, Postgres)",
    "Rate limiting and reputation management",
    "Auth provider companions (Auth0, Clerk, Firebase, Supabase)"
  ],
  "publicApiSurface": [
    "@agentdoor/core - Core library with crypto, auth, and storage",
    "@agentdoor/sdk - Agent-side TypeScript SDK",
    "@agentdoor/express - Express.js middleware",
    "@agentdoor/next - Next.js App Router adapter",
    "@agentdoor/hono - Hono middleware",
    "@agentdoor/fastify - Fastify plugin",
    "@agentdoor/cli - CLI tool (npx agentdoor init)",
    "@agentdoor/detect - Agent traffic detection",
    "agentdoor - Python agent SDK",
    "agentdoor-fastapi - FastAPI middleware",
    "/.well-known/agentdoor.json - Discovery endpoint",
    "/agentdoor/register - Agent registration endpoint",
    "/agentdoor/register/verify - Challenge verification endpoint",
    "/agentdoor/auth - Token refresh endpoint"
  ]
